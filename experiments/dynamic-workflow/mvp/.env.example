# Copy to .env or export these in your shell.
# Do not commit real credentials. Rotate any key that has been committed before.

OPENAI_BASE_URL=https://your-openai-compatible-endpoint.example/v1
OPENAI_API_KEY=replace-me
MODEL_NAME=replace-me

# Optional budgets. Workspace and capability allowlists live in .workflow/config.json.
WORKFLOW_MAX_AGENTS=32
WORKFLOW_MAX_WORKFLOWS=32
WORKFLOW_MAX_CONCURRENCY=4
WORKFLOW_AGENT_TIMEOUT_MS=90000

# Only needed when .workflow/config.json points to a search adapter with apiKeyEnv.
WORKFLOW_WEB_SEARCH_API_KEY=
